# Шаблон для команди: скопіюйте у `.env` (реальні значення тільки там; цей файл комітять без секретів).
# Скопіюйте як `.env` поруч із package.json. Лапки не обовʼязкові:
#   NUXT_GEMINI_API_KEY=AIza...   (рекомендовано)
#   NUXT_GEMINI_API_KEY="AIza..." (зазвичай теж ок)
NUXT_GEMINI_API_KEY=

# PostgreSQL (Prisma). Приклад для Neon:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Зашифрована cookie-сесія (iron-session). Мінімум 32 символи; для dev:
# openssl rand -base64 32
NUXT_SESSION_SECRET=

# Необовʼязково. За замовчуванням: gemini-2.5-flash.
# При 429/503 або недоступній моделі — автоматичний fallback на gemini-2.5-flash-lite.
# gemini-1.5-flash більше не підтримується API (404).
# NUXT_GEMINI_MODEL=gemini-2.5-flash-lite
