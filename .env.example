# Шаблон для команди: скопіюйте у `.env` (реальні значення тільки там; цей файл комітять без секретів).
# Скопіюйте як `.env` поруч із package.json. Лапки не обовʼязкові:
#   NUXT_GEMINI_API_KEY=AIza...   (рекомендовано)
#   NUXT_GEMINI_API_KEY="AIza..." (зазвичай теж ок)
NUXT_GEMINI_API_KEY=

# Необовʼязково. За замовчуванням: gemini-2.5-flash (1.5-flash більше не підтримується API).
# Швидший/дешевший варіант: gemini-2.5-flash-lite
# NUXT_GEMINI_MODEL=gemini-2.5-flash-lite
